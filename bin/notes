#!/bin/bash
set -e

usage() {
cat << EOF
usage: notes [mode] [arguments]
Quickly create, view or edit notes

If a note name is required but left out, fzf will be used to select one.
The default mode is 'open'.

Modes:
  a -- Append
    Usage: notes a <note_name> [text_to_append]
    Any text after the note name will be appended to it.
  aa -- Find and append
    Usage: notes aa [text_to_append]
    Select a note with fzf and append the given text.
  d -- Delete
    Usage: notes d [note_name]
    Remove selected note.
  r -- Read
    Usage: notes r [note_name]
    Print content of note on stdout.
  o -- Open (Default)
    Usage: notes o [note_name]
    Open note in '$EDITOR'.
  s -- Open in split
    Usage: notes s [note_name]
    Open note in a tmux split if available, otherwise opens in the current pane.
  l -- List
    List all available notes.
  n -- Nickname
    Usage: notes n <nickname> [note_name]
    Create a nickname (symlink) for a note.
EOF
}

find_note() {
  if ! [[ -x "$(command -v fzf)" ]]; then
    echo "fzf is not installed, which is required for finding notes." >&2
    exit 1
  fi
  if [[ -x "$(command -v unbuffer)" && -x "$(command -v glow)" ]]; then
    PREVIEW="unbuffer glow"
  elif [[ -x "$(command -v bat)" ]]; then
    PREVIEW="bat --style=plain --color=always"
  else
    PREVIEW="cat"
  fi
  if [[ -x "$(command -v fzf)" ]]; then
    # Quote the preview command to handle filenames with spaces
    # Exit if fzf is cancelled (non-zero exit) or if the selection is empty
    file=$(find "$NOTES_DIR" -type f -printf "%f\n" | sed 's/\.md$//' | fzf --preview="${PREVIEW} \"${NOTES_DIR}/{}.md\"")
    if [[ $? -ne 0 || -z "$file" ]]; then
      exit 1
    fi
    echo "${file}.md"
  fi
}

if [[ -z "$EDITOR" ]]; then
  EDITOR=vim
fi

if [[ -z "$NOTES_DIR" ]]; then
  NOTES_DIR=~/.notes
fi

if [[ ! -d "$NOTES_DIR" ]]; then
  mkdir -p "$NOTES_DIR"
fi

mode="open"
case ${1} in
  a)
    mode="append"
    shift
    ;;
  aa)
    mode="find_append"
    shift
    ;;
  d)
    mode="delete"
    shift
    ;;
  r)
    mode="read"
    shift
    ;;
  o)
    mode="open"
    shift
    ;;
  s)
    if [[ -n $TMUX ]]; then
      mode="split"
    else
      echo "Must run in tmux to split" >&2
      mode="open"
    fi
    shift
    ;;
  l) # List
    ls "$NOTES_DIR" --color --file-type
    exit 0
    ;;
  n)
    mode="nickname"
    shift
    if [[ $# == 0 ]]; then
      echo "n requires at least 1 argument" >&2
      exit 1
    fi
    nickname=$1
    shift
    ;;
  h | -h | --help)
    usage
    exit 1
    ;;
esac

if [[ $# == 0 || $mode == "find_append" ]]; then
  filename=$(find_note)
else
  filename=${1%.md}.md
  shift
fi

file=${NOTES_DIR}/$filename

case ${mode} in
  append | find_append)
    echo "$@" >> "$file"
    ;;
  delete)
    read -rp "Do you want to delete $file? " -n 1
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
      rm -f "$file"
    fi
    ;;
  read)
    cat "$file"
    ;;
  open)
    $EDITOR "$file"
    ;;
  split)
    tmux split-window -h "$EDITOR" "$file"
    ;;
  nickname)
    ln -fs "$file" "${NOTES_DIR}/$nickname"
  esac
